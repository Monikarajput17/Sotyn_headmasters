{
  "name": "business-erp",
  "version": "1.0.0",
  "description": "Business ERP - Sales, Procurement, Installation, HR & Expense Management",
  "main": "server/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "install-all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.1",
    "@sentry/node": "^8.45.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "compression": "^1.7.4",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^1.1.4",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.2",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  }
}
