# --- SEPL ERP read-only MCP connector config -------------------------------
# Copy this file to ".env" and fill in the values. Do NOT commit .env.

# Live ERP base URL (no trailing slash). Mam will provide this.
ERP_BASE_URL=https://your-erp-domain.com

# Authentication — choose ONE of the two:
#
# (A) Static token (paste a bearer token issued to a read-only service user):
# ERP_TOKEN=

# (B) Service-account login (RECOMMENDED). Use a dedicated read-only user,
#     never the admin account. The connector logs in and refreshes itself.
ERP_USER=claude-readonly
ERP_PASS=change-me

# --- HTTP mode only (Claude app connector) ---------------------------------
# Port the HTTP transport listens on when MCP_TRANSPORT=http
MCP_HTTP_PORT=8788
# Shared secret clients must send as "Authorization: Bearer <value>" to reach
# /mcp. Leave blank to disable the gate (only safe behind a private network).
MCP_BEARER=
