PORT=5000
JWT_SECRET=your-secure-secret-key-here-change-this
NODE_ENV=production

# ── Twilio (WhatsApp + SMS on complaint registration) ──────────────
# Get these from https://console.twilio.com/ once you log in.
# Leave any of them blank to disable that channel — the complaint will
# still save, just no message will go out.

# Twilio Account SID (starts with "AC…") — Console → Account → API keys & tokens
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token — Console → Account → API keys & tokens (click "view" to reveal)
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here

# WhatsApp sender number in E.164 format, WITHOUT the "whatsapp:" prefix
# (the notify service adds the prefix automatically).
# Sandbox sender for testing is +14155238886 — Console → Messaging → Try it out → Send a WhatsApp message
# In production this becomes the WhatsApp Business sender we provision.
TWILIO_WHATSAPP_FROM=+14155238886

# SMS sender number in E.164 format. Console → Phone Numbers → Manage → Active numbers
# Indian DLT-registered sender ID can also be used here.
TWILIO_SMS_FROM=+12345678901
